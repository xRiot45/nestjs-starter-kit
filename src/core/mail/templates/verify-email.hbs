<div class='text-center mb-8'>
    <h1 class='text-2xl sm:text-3xl font-bold text-gray-800 mb-3'>
        Verify your email address
    </h1>
    <p class='text-base text-gray-500'>
        Hi
        <strong>{{username}}</strong>, welcome to
        <strong>{{appName}}</strong>
        👋
    </p>
</div>

<div class='flex justify-center mb-8'>
    <div class='bg-gradient-to-br from-primary-500 to-primary-600 rounded-full p-5 shadow-lg shadow-primary-500/30'>
        <svg
            xmlns='http://www.w3.org/2000/svg'
            class='h-10 w-10 text-white'
            fill='none'
            viewBox='0 0 24 24'
            stroke='currentColor'
            stroke-width='2'
        >
            <path stroke-linecap='round' stroke-linejoin='round' d='M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z' />
        </svg>
    </div>
</div>

<div class='text-center mb-8'>
    <p class='text-gray-600 leading-relaxed'>
        Thanks for signing up! To get started and secure your account, please confirm your email address by clicking the
        button below.
    </p>
</div>

<div class='text-center mb-8'>
    <a
        href='{{verifyLink}}'
        class='inline-block w-full sm:w-auto px-8 py-4 bg-primary-500 text-white font-semibold text-sm uppercase tracking-wider rounded-xl shadow-md hover:bg-primary-600 transition'
    >
        Verify Email
    </a>
</div>

<div class='bg-gray-50 border border-gray-200 rounded-lg p-4 mb-8 text-left'>
    <p class='text-sm text-gray-700 font-medium mb-1'>
        ⏳ Link expires in 15 minutes
    </p>
    <p class='text-xs text-gray-500'>
        This verification link is time-sensitive for your security. If it expires, you can request a new one from the
        login page.
    </p>
</div>

<div class='border-t border-gray-100 pt-6 text-center'>
    <p class='text-xs text-gray-400 mb-2'>
        If the button doesn’t work, copy and paste this URL into your browser:
    </p>
    <a href='{{verifyLink}}' class='text-xs text-primary-600 hover:underline break-all block'>
        {{verifyLink}}
    </a>
</div>